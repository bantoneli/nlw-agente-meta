{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true, // Importante: O TS apenas checa os tipos. O build será feito por um bundler (como Vite/Webpack)
    "jsx": "preserve", // Mantém o JSX intacto (útil se for usar React)

    /* Regras rigorosas de qualidade */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"] // Pasta onde seu código vai morar
}
